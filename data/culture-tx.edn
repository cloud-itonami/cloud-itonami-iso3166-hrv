#:culture{:id "hrv.dish.zagorski-strukli", :name "Zagorski štrukli", :country "HRV", :kind :dish, :summary "Traditional Croatian pastry dish of thin dough with fillings such as cottage cheese, eggs and sour cream, boiled or baked, from the Hrvatsko Zagorje and Zagreb regions in the north of the country.", :url "https://en.wikipedia.org/wiki/Zagorski_%C5%A1trukli", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "hrv.dish.soparnik", :name "Soparnik", :country "HRV", :kind :dish, :summary "Traditional Croatian savory pie from the Dalmatian region of Poljica, filled with Swiss chard, onion, garlic and olive oil, baked between thin sheets of unleavened dough.", :url "https://en.wikipedia.org/wiki/Soparnik", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "hrv.dish.pasticada", :name "Pašticada", :country "HRV", :kind :dish, :summary "Braised beef dish in a sweet and sour sauce, popular in Croatia and originating from Dalmatia, traditionally served at special occasions.", :url "https://en.wikipedia.org/wiki/Pa%C5%A1ticada", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "hrv.beverage.maraschino", :name "Maraschino", :country "HRV", :kind :beverage, :summary "Liqueur obtained from the distillation of Marasca cherries; industrial-scale production began in Zadar, Croatia, in 1759.", :url "https://en.wikipedia.org/wiki/Maraschino", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "hrv.product.pag-cheese", :name "Pag cheese", :country "HRV", :kind :product, :summary "Hard sheep's-milk cheese from the Croatian Adriatic island of Pag, aged between 2 and 18 months, with protected designation of origin status.", :url "https://en.wikipedia.org/wiki/Pag_cheese", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "hrv.craft.licitar", :name "Licitar", :country "HRV", :kind :craft, :summary "Colorfully decorated biscuits of sweet honey dough, part of Croatia's cultural heritage; the gingerbread craft from Northern Croatia was inscribed on UNESCO's intangible cultural heritage list in 2010.", :url "https://en.wikipedia.org/wiki/Licitar", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "hrv.festival.sinjska-alka", :name "Sinjska alka", :country "HRV", :kind :festival, :summary "Equestrian tournament held annually in Sinj, Croatia, since 1715, in which horsemen at full gallop aim lances at a hanging metal ring; inscribed as UNESCO intangible cultural heritage in 2010.", :url "https://en.wikipedia.org/wiki/Sinjska_alka", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
